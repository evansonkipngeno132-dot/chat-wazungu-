# PayHero API Configuration Example
# Copy this file to '.env' and fill in your actual credentials.

# PayHero API Credentials (from your PayHero Developer Dashboard)
# Register at https://app.payhero.co.ke
PAYHERO_API_USERNAME=YOUR_PAYHERO_USERNAME
PAYHERO_API_PASSWORD=YOUR_PAYHERO_PASSWORD

# Your PayHero Payment Channel ID (found under Payment Channels in dashboard)
PAYHERO_CHANNEL_ID=YOUR_CHANNEL_ID

# Publicly accessible URL for PayHero to send transaction status updates
# For local dev, use ngrok. For production, use your Render domain.
PAYHERO_CALLBACK_URL=https://yourdomain.com/api/payhero/callback
